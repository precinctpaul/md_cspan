# Copy this file to .env and fill in your real values.
# Do NOT commit .env.

CSPAN_API_KEY=mFBA9yMxOc6yQxp1EtnkT6eNezCOTKHG8KXw7g89
CSPAN_API_BASE_URL=https://www.c-span.org/api
CSPAN_AUTH_MODE=header
CSPAN_API_KEY_HEADER=x-api-key
CSPAN_API_KEY_PARAM=api_key
CSPAN_TIMEOUT_SECONDS=30

# Use the base URL from the C-SPAN API documentation you received.
# Example placeholder only:
CSPAN_API_BASE_URL=https://api.c-span.org

# Auth mode options:
# bearer        -> Authorization: Bearer <key>
# header        -> custom header name from CSPAN_API_KEY_HEADER
# query_param   -> query parameter name from CSPAN_API_KEY_PARAM
CSPAN_AUTH_MODE=bearer

# Only used when CSPAN_AUTH_MODE=header
CSPAN_API_KEY_HEADER=X-API-Key

# Only used when CSPAN_AUTH_MODE=query_param
CSPAN_API_KEY_PARAM=api_key

# Optional default timeout, in seconds
CSPAN_TIMEOUT_SECONDS=30







